02_InvestSight/__pycache__/
02_InvestSight/**/__pycache__/
02_InvestSight/*.py[cod]
02_InvestSight/**/*.py[cod]

# 測試相關
02_InvestSight/.pytest_cache/
02_InvestSight/coverage.xml
02_InvestSight/htmlcov/
02_InvestSight/.tox/

