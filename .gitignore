02_InvestSight/**/*.env
02_InvestSight/.env.*
02_InvestSight/!*.env.example

# Token 與認證（敏感）
02_InvestSight/pri/
02_InvestSight/**/*.tokens.json
01_python_ms_graph/pri/

# 日誌檔案
02_InvestSight/logs/*.log
02_InvestSight/logs/**/*.log

# 抓取的數據（避免大量數據提交）
